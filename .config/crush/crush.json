{
  "$schema": "https://charm.land/crush.json",
  "options": {
    "skills_paths": ["~/.agents/skills"],
    "attribution": {
      "trailer_style": "none"
    }
  },
  "permissions": {
    "allowed_tools": [
      "agent",
      "agentic_fetch",
      "bash",
      "crush_info",
      "crush_logs",
      "download",
      "edit",
      "fetch",
      "glob",
      "grep",
      "job_kill",
      "job_output",
      "ls",
      "lsp_diagnostics",
      "lsp_references",
      "lsp_restart",
      "multiedit",
      "sourcegraph",
      "todos",
      "view",
      "write"
    ]
  }
}
